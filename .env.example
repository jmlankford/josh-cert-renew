# ── Required ──────────────────────────────────────────────────────────────────
# HTTP Basic Auth password — gates ALL routes. Change before first run.
ADMIN_PASSWORD=changeme

# Fernet encryption key for all stored secrets (Cloudflare tokens, cPanel creds).
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# The app will refuse to start if this is not set.
MASTER_SECRET=generate-a-strong-random-secret-here

# ── ACME / Let's Encrypt ───────────────────────────────────────────────────────
# Email address registered with Let's Encrypt for expiry notices.
ACME_EMAIL=your@email.com

# ── Scheduling ─────────────────────────────────────────────────────────────────
# Daily auto-renewal time in HH:MM (24-hour, UTC). Default: 02:00
RENEWAL_CRON_TIME=02:00

# ── Server ────────────────────────────────────────────────────────────────────
# Internal container port. Must match Dockerfile EXPOSE and uvicorn CMD.
PORT=8443
